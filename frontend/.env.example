# ============================================
# FRONTEND ENV (consumed by Next.js on Vercel)
# Only NEXT_PUBLIC_* values reach the browser
# Copy to frontend/.env.local for local dev
# Never commit frontend/.env.local
# ============================================

# Supabase (anon key is safe to expose; RLS policies enforce access)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Turnstile site key (public). In local dev the app uses Cloudflare's
# test site key by default (works on localhost). To use the production key locally
# (required for Supabase OTP with production captcha), add localhost under
# Cloudflare Turnstile → Hostname Management, then set:
# NEXT_PUBLIC_TURNSTILE_USE_PRODUCTION_IN_DEV=true
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# NEXT_PUBLIC_TURNSTILE_USE_PRODUCTION_IN_DEV=true

# Public site URL (used for OAuth redirects and email links)
NEXT_PUBLIC_SITE_URL=https://codemoteam.org

# Dev Editor toggle (true only in staging, never in production)
NEXT_PUBLIC_DEV_EDITOR=false

# --- Mailjet (server-only — used by /api/email/send and admin notifications) ---
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
MAILJET_FROM_EMAIL=noreply@codemoteam.org
MAILJET_FROM_NAME=Codemo Teams

# Service-role key — server-only (admin panel, Route Handlers)
SUPABASE_SERVICE_ROLE_KEY=

# Donation OCR (Python FastAPI — services/donation-ocr)
# Local: http://localhost:8001  |  Production: deploy Docker image and set URL here
DONATION_OCR_URL=http://localhost:8001
# Optional shared secret (must match DONATION_OCR_API_KEY on the Python service)
DONATION_OCR_API_KEY=
