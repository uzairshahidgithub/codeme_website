# =============================================================================
# Postal SMTP server environment
# Copy to ./smtp/.env on the Oracle VM. This file is gitignored.
# =============================================================================

# --- MariaDB credentials -----------------------------------------------------
# Generate with: openssl rand -hex 24
MARIADB_ROOT_PASSWORD=
MARIADB_DATABASE=postal
MARIADB_USER=postal
MARIADB_PASSWORD=

# --- Postal database connection (read by postal.yml via env substitution) ---
POSTAL_DB_URL=mysql2://postal:${MARIADB_PASSWORD}@postal-mariadb:3306/postal
POSTAL_REDIS_URL=redis://postal-redis:6379/0

# --- Hostnames (must match Cloudflare DNS records) ---------------------------
SMTP_DOMAIN=mail.codemoteam.org
POSTAL_WEB_HOST=postal.codemoteam.org

# --- TLS cert paths (Let's Encrypt, mounted from host) -----------------------
TLS_CERT_PATH=/etc/letsencrypt/live/mail.codemoteam.org/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/mail.codemoteam.org/privkey.pem

# --- Postal admin bootstrap --------------------------------------------------
# Initial admin user created via `postal make-user` after first compose up.
# Email here is just a hint for setup-guide.md, not consumed by Postal.
POSTAL_ADMIN_EMAIL=admin@codemoteam.org
