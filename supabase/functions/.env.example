# =============================================================================
# Edge Function secrets
# Apply with: supabase secrets set --env-file ./supabase/functions/.env
# This file is gitignored. Never commit a populated copy.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Mailjet (transactional email) -------------------------------------------
# API Key = public key from Mailjet dashboard
MAILJET_API_KEY=
# Secret Key = private key from Mailjet dashboard
MAILJET_SECRET_KEY=

# Verified sender — must be added in Mailjet → Sender addresses & domains
EMAIL_FROM=noreply@codemoteam.org
EMAIL_FROM_NAME=Codemo Teams
MAILJET_FROM_EMAIL=noreply@codemoteam.org
MAILJET_FROM_NAME=Codemo Teams

# Optional SMTP fallback (Mailjet SMTP uses API key as username, secret as password)
SMTP_HOST=in-v3.mailjet.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Cloudflare Turnstile ----------------------------------------------------
TURNSTILE_SECRET_KEY=
