# =============================================================================
# Edge Function secrets
# Apply with: supabase secrets set --env-file ./supabase/functions/.env
# This file is gitignored. Never commit a populated copy.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Project URL (same as NEXT_PUBLIC_SUPABASE_URL on the frontend)
SUPABASE_URL=

# Service role key — bypasses RLS. Server-side only, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Postal SMTP (used by the send-email Edge Function) ----------------------
# Host that runs Postal v3 (Oracle Cloud Always-Free VM). See smtp/setup-guide.md.
SMTP_HOST=mail.codemoteam.org
# 587 = STARTTLS submission (recommended). 465 = implicit TLS. 25 = unencrypted relay.
SMTP_PORT=587
# Credentials minted in Postal Admin UI → Server → Credentials → New (type SMTP).
SMTP_USER=
SMTP_PASS=

# Verified sender address. Domain must be provisioned in Postal first.
EMAIL_FROM=noreply@codemoteam.org

# --- Cloudflare Turnstile ----------------------------------------------------
# Server-side secret used by the verify-turnstile Edge Function.
# Get from: Cloudflare Dashboard → Turnstile → your site → Settings.
TURNSTILE_SECRET_KEY=
