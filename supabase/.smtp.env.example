# =============================================================================
# Supabase Auth → SMTP Settings (Dashboard)
#
# Paste these into: Supabase Dashboard → Project Settings → Auth → SMTP Settings
# Also enable "Confirm email" and "Secure email change" under Auth → Providers → Email
# =============================================================================

SMTP_SENDER_NAME=Codemo Teams
SMTP_SENDER_EMAIL=noreply@codemoteam.org

# Mailjet SMTP relay (recommended for Supabase Auth emails)
# API Key = public key, Secret Key = SMTP password
# Docs: https://dev.mailjet.com/smtp-relay/overview/
SMTP_HOST=in-v3.mailjet.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

SMTP_MAX_FREQUENCY_SECONDS=30
