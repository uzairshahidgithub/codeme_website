# =============================================================================
# Supabase Auth → SMTP Settings (Dashboard)
#
# Paste into: Supabase Dashboard → Project Settings → Auth → SMTP Settings
# DNS + deliverability: see mailjet-dns-records.md in this folder
# =============================================================================

SMTP_SENDER_NAME=Codemo Teams

# MUST match the domain you verified in Mailjet (Senders & Domains).
# Your test used noreply@codemoteams.org — if that is verified, use it here.
# If codemoteam.org is verified instead, use noreply@codemoteam.org.
SMTP_SENDER_EMAIL=noreply@codemoteams.org

# Mailjet SMTP relay
SMTP_HOST=in-v3.mailjet.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

SMTP_MAX_FREQUENCY_SECONDS=30
