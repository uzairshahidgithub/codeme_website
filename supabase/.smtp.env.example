# =============================================================================
# Supabase Auth → SMTP Settings (Dashboard)
#
# These values are NOT loaded by any code. They are pasted into the Supabase
# Dashboard once: Project Settings → Auth → SMTP Settings.
#
# This file is purely a copy-paste reference so the credentials live alongside
# your other secrets in your password manager. Keep a populated copy out of git.
# =============================================================================

# Sender shown to users in the From: header
SMTP_SENDER_NAME=Codemo Teams
SMTP_SENDER_EMAIL=noreply@codemoteam.org

# Postal SMTP relay (self-hosted on Oracle Cloud Always-Free VM)
# Provisioned per smtp/setup-guide.md.
SMTP_HOST=mail.codemoteam.org
SMTP_PORT=587
SMTP_USERNAME=

# Password = the SMTP credential's password from Postal Admin UI →
# Server → Credentials. It is NOT the Postal admin login.
SMTP_PASSWORD=

# Maximum email frequency per address. Supabase default is 1 minute; we relax to
# 30 seconds. Configured under Auth → Email → "Email frequency".
SMTP_MAX_FREQUENCY_SECONDS=30
